# ================================================
# ARIA — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in every value.
# ================================================

# --- SUPABASE ---
# https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI ---
# Required — Whisper (voice transcription) + note generation
OPENAI_API_KEY=sk-proj-...
# Optional — primary chat model for note/letter generation. Defaults to gpt-5.5.
# Set to gpt-4o to disable GPT-5.5. (Falls back gpt-5.5 -> gpt-4o -> Claude.)
OPENAI_MODEL=gpt-5.5
# Optional — used as automatic fallback if OpenAI fails
ANTHROPIC_API_KEY=sk-ant-...

# --- STRIPE ---
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs created in Stripe dashboard for each plan
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_SOLO_AUD_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_SOLO_NZD_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_SOLO_PRO_AUD_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_SOLO_PRO_NZD_PRICE_ID=price_...

# --- APP ---
# Production: https://ariacare.app — local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://ariacare.app

# --- ENCRYPTION ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key

# --- RESEND (transactional email) ---
# https://resend.com — used for compliance reminders, trial expiry, staff invites.
# Verify your sending domain before going live.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Aria Care <noreply@ariacare.app>

# --- CRON SECURITY ---
# Required header on Vercel cron invocations: Authorization: Bearer <CRON_SECRET>
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-cron-secret

# --- ADMIN SETUP ---
# After deploy, run this in Supabase SQL Editor to grant admin access:
#   SELECT make_admin('your-email@example.com');
# Then visit https://yourdomain.com/admin
